{
	"name": "nightclub-guestlist",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:emulators": "vite dev --mode emulator",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:functions": "vitest run --config functions/vitest.config.mjs --reporter verbose",
		"firebase:emulators": "firebase emulators:start --only auth,firestore,functions",
		"firebase:deploy": "firebase deploy --only firestore:rules,firestore:indexes,functions",
		"firebase:seed:events": "node scripts/seed-events.mjs"
	},
	"devDependencies": {
		"@opentelemetry/api": "^1.9.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/postcss": "^4.2.1",
		"@tailwindcss/vite": "^4.2.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"autoprefixer": "^10.4.24",
		"firebase-admin": "^13.7.0",
		"jsdom": "^28.1.0",
		"postcss": "^8.5.6",
		"svelte": "^5.51.0",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.2.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@types/qrcode": "^1.5.6",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"firebase": "^12.9.0",
		"lucide-svelte": "^0.575.0",
		"nanoid": "^5.1.6",
		"qrcode": "^1.5.4",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	}
}
