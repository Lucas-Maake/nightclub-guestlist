rules_version = '2';

service cloud.firestore {
	match /databases/{database}/documents {
		function signedIn() {
			return request.auth != null;
		}

		function reservationDoc(reservationId) {
			return get(/databases/$(database)/documents/reservations/$(reservationId));
		}

		function reservationPath(reservationId) {
			return /databases/$(database)/documents/reservations/$(reservationId);
		}

		function reservationPublicPath(reservationId) {
			return /databases/$(database)/documents/reservationPublic/$(reservationId);
		}

		function guestPath(reservationId, uid) {
			return /databases/$(database)/documents/reservations/$(reservationId)/guests/$(uid);
		}

		function isHost(reservationId) {
			return signedIn() && reservationDoc(reservationId).data.hostUid == request.auth.uid;
		}

		function isHostAfter(reservationId) {
			return signedIn() &&
				existsAfter(reservationPath(reservationId)) &&
				getAfter(reservationPath(reservationId)).data.hostUid == request.auth.uid;
		}

		function isOwnGuest(uid) {
			return signedIn() && request.auth.uid == uid;
		}

		function validReservationPublicCreate(reservationId) {
			return request.resource.data.reservationId == reservationId &&
				request.resource.data.acceptedCount == 0 &&
				request.resource.data.declinedCount == 0 &&
				request.resource.data.guestListVisibility == 'hidden';
		}

		function publicGuestListVisible(reservationId) {
			return exists(reservationPublicPath(reservationId)) &&
				get(reservationPublicPath(reservationId)).data.guestListVisibility == 'visible';
		}

		function reservationHostUidUnchanged() {
			return !request.resource.data.diff(resource.data).changedKeys().hasAny(['hostUid']);
		}

		match /reservationPublic/{reservationId} {
			allow get, list: if true;
			allow create: if isHostAfter(reservationId) && validReservationPublicCreate(reservationId);
			allow update, delete: if false;

			match /attendees/{uid} {
				allow get, list: if publicGuestListVisible(reservationId);
				allow create, update, delete: if false;
			}
		}

		match /reservationDebug/{reservationId} {
			allow get: if true;
			allow list: if false;
			allow create: if signedIn() && request.resource.data.hostUid == request.auth.uid;
			allow update, delete: if isHost(reservationId);
		}

		match /events/{eventId} {
			allow get, list: if resource.data.published == true;
			allow create, update, delete: if false;

			match /ticketTiers/{tierId} {
				allow get, list: if exists(/databases/$(database)/documents/events/$(eventId)) &&
					get(/databases/$(database)/documents/events/$(eventId)).data.published == true;
				allow create, update, delete: if false;
			}
		}

		match /reservations/{reservationId} {
			allow create: if signedIn() && request.resource.data.hostUid == request.auth.uid;
			allow read, delete: if signedIn() && resource.data.hostUid == request.auth.uid;
			allow update: if signedIn() &&
				resource.data.hostUid == request.auth.uid &&
				reservationHostUidUnchanged();

			match /guests/{uid} {
				allow get: if isHost(reservationId) || isOwnGuest(uid);
				allow list: if isHost(reservationId);
				allow create, update, delete: if false;
			}

			match /waitlist/{uid} {
				allow get: if isHost(reservationId) || isOwnGuest(uid);
				allow list: if isHost(reservationId);
				allow create, update: if isOwnGuest(uid);
				allow delete: if isHost(reservationId) || isOwnGuest(uid);
			}

			match /comments/{commentId} {
				allow get, list: if true;
				allow create: if signedIn() &&
					request.resource.data.keys().hasOnly(['uid', 'displayName', 'text', 'createdAt']) &&
					request.resource.data.uid == request.auth.uid &&
					request.resource.data.displayName is string &&
					request.resource.data.displayName.size() > 0 &&
					request.resource.data.displayName.size() <= 48 &&
					request.resource.data.text is string &&
					request.resource.data.text.size() > 0 &&
					request.resource.data.text.size() <= 280;
				allow update, delete: if false;
			}
		}

		match /users/{uid} {
			allow create, read, update, delete: if signedIn() && request.auth.uid == uid;
		}
	}
}
